@* 
    App.razor er dit routing-entrypoint.
    Router finder den rigtige page baseret på URL, og viser den i MainLayout.
*@

<CascadingAuthenticationState>
<Router AppAssembly="@typeof(App).Assembly">

    @* Når en route findes *@
    <Found Context="routeData">
        @* AuthorizeRouteView renderer den matchende page og understøtter [Authorize] på routes. *@
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                <LayoutView Layout="@typeof(MainLayout)">
                    <p role="alert">Du skal være logget ind for at se denne side.</p>
                </LayoutView>
            </NotAuthorized>
        </AuthorizeRouteView>

        @* Flytter fokus ved navigation (godt for tilgængelighed) *@
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>

    @* Når der ikke findes en route *@
    <NotFound>
        <PageTitle>Not found</PageTitle>

        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>

</Router>
</CascadingAuthenticationState>
