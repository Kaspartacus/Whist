@using Core
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@inject Service.HighlightServices.IHighlightService HighlightService
@inject Service.AuthServices.IAuthService AuthService
@inject Service.UploadServices.IUploadService UploadService
@inject IJSRuntime JS

@if (showModal)
{
    <div class="modal-backdrop" 
         tabindex="0"
         @onkeydown="HandleKeyDown"
         @onmousedown="StartBackdropClick"
         @onclick="CloseFromBackdrop">
        @* Stop klik inde i modal fra at lukke den *@
        <div class="modal-container"
             @onmousedown:stopPropagation="true"
             @onclick:stopPropagation="true">
            <h3 class="modal-title">
                @(HighlightToEdit is null ? "Opret nyt highlight" : "Rediger highlight")
            </h3>

            @* oninput giver live-opdatering mens man skriver *@
            <input class="modal-input"
                   placeholder="Titel"
                   maxlength="80"
                   @bind-value="Title"
                   @bind-value:event="oninput" />

            <textarea class="modal-textarea"
                      placeholder="Beskrivelse"
                      maxlength="400"
                      @bind-value="Description"
                      @bind-value:event="oninput"
                      @onkeydown="HandleDescriptionKeyDown"
                      @onkeydown:stopPropagation="true"></textarea>

            @* Upload billede via backend, som gemmer komprimeret version i Blob Storage og får en URL retur *@
            <label for="file-upload" class="custom-file-label">📷 Vedhæft billede</label>
            <div class="file-input-wrapper">
                <InputFile id="file-upload" OnChange="HandleImageUpload" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
            </div>

            @* Preview viser URL'en (enten eksisterende billede eller nyligt uploadet) *@
            @if (!string.IsNullOrWhiteSpace(ImagePreview))
            {
                <img src="@ImagePreview" alt="Preview" class="modal-image-preview" />
            }

            @if (IsUploadingImage)
            {
                <div class="upload-status">Uploader billede...</div>
            }

            <label class="modal-checkbox">
                <input type="checkbox" @bind="IsPrivate" />
                Gør privat (kun synlig for medlemmer)
            </label>

            @* Upload fejl (fx for stor fil eller server-fejl) *@
            @if (!string.IsNullOrWhiteSpace(UploadErrorMessage))
            {
                <div style="color: red; font-size: 0.9rem;">@UploadErrorMessage</div>
            }

            @* Valideringsfejl (titel/beskrivelse mangler) *@
            @if (!string.IsNullOrWhiteSpace(ValidationErrorMessage))
            {
                <div style="color: red; font-size: 0.9rem;">@ValidationErrorMessage</div>
            }

            <div class="modal-actions">
                <button @ref="ConfirmButtonRef" class="modal-btn primary" disabled="@IsUploadingImage" @onclick="SaveHighlightAsync">
                    @(HighlightToEdit is null ? "Opret highlight" : "Gem ændringer")
                </button>
                <button class="modal-btn cancel" @onclick="Close">Annuller</button>
            </div>
        </div>
    </div>
}

@code {
    // =========================
    // Modal state + formfelter
    // =========================
    private bool showModal;

    private string Title = "";
    private string Description = "";

    private bool IsPrivate;

    // Upload state
    private IBrowserFile? UploadedImage;
    private string? ImagePreview;               // URL til billede (fra UploadService)
    private string? UploadedImageUrl;
    private string? UploadErrorMessage;
    private bool IsUploadingImage;
    private int _imageUploadVersion;

    private const string BrowserOptimizedImageType = "image/jpeg";
    private const int MaxClientImageDimension = 1600;
    private const long MaxPreviewBytes = 3 * 1024 * 1024;
    
    // Fokus-håndtering (så Enter virker direkte)
    private ElementReference ConfirmButtonRef;
    private bool _shouldFocusConfirmButton;
    private bool _isScrollLocked;
    private bool _backdropClickStarted;

    // Validering
    private string? ValidationErrorMessage;

    // =========================
    // Params / callbacks
    // =========================

    /// <summary>
    /// Kald fra parent, når highlight er oprettet/ændret, så listen kan reloades.
    /// </summary>
    [Parameter] public EventCallback OnHighlightAdded { get; set; }

    /// <summary>
    /// Hvis sat: modal er i "edit mode".
    /// Hvis null: modal er i "create mode".
    /// </summary>
    [Parameter] public Highlight? HighlightToEdit { get; set; }

    // =========================
    // Public API (kaldes via @ref fra parent)
    // =========================

    /// <summary>
    /// Åbner modal og udfylder felter hvis det er redigering.
    /// </summary>
    public void Show(Highlight? highlight = null)
    {
        HighlightToEdit = highlight;

        // Nulstil fejlbeskeder
        UploadErrorMessage = null;
        ValidationErrorMessage = null;

        if (HighlightToEdit is not null)
        {
            // Redigering: udfyld eksisterende data
            Title = HighlightToEdit.Title;
            Description = HighlightToEdit.Description;
            ImagePreview = HighlightToEdit.ImageUrl;
            UploadedImageUrl = HighlightToEdit.ImageUrl;

            // Vigtigt: bevar privacy-state ved redigering
            IsPrivate = HighlightToEdit.IsPrivate;
        }
        else
        {
            // Opret: reset felter
            Title = "";
            Description = "";
            UploadedImage = null;
            ImagePreview = null;
            UploadedImageUrl = null;
            IsPrivate = false;
        }

        showModal = true;
        _ = LockModalScrollAsync();
        _shouldFocusConfirmButton = true;
        
        StateHasChanged();
    }

    /// <summary>
    /// Lukker modal og rydder felter.
    /// </summary>
    private async Task Close()
    {
        showModal = false;
        await UnlockModalScrollAsync();

        Title = "";
        Description = "";
        UploadedImage = null;
        ImagePreview = null;
        UploadedImageUrl = null;
        IsPrivate = false;

        UploadErrorMessage = null;
        ValidationErrorMessage = null;
        IsUploadingImage = false;
        _imageUploadVersion++;
    }

    // =========================
    // Upload
    // =========================

    /// <summary>
    /// Uploader billedet og får en offentlig URL retur (som vi gemmer i ImagePreview).
    /// </summary>
    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        UploadedImage = e.File;
        UploadedImageUrl = null;
        UploadErrorMessage = null;
        IsUploadingImage = true;
        var uploadVersion = ++_imageUploadVersion;

        try
        {
            var optimizedImage = await UploadedImage.RequestImageFileAsync(
                BrowserOptimizedImageType,
                MaxClientImageDimension,
                MaxClientImageDimension);

            ImagePreview = await CreatePreviewDataUrlAsync(optimizedImage);
            await InvokeAsync(StateHasChanged);

            var resultUrl = await UploadService.UploadImageAsync(optimizedImage);

            if (uploadVersion != _imageUploadVersion)
                return;

            if (!string.IsNullOrWhiteSpace(resultUrl))
            {
                UploadedImageUrl = resultUrl;
            }
            else
            {
                UploadErrorMessage = "Upload mislykkedes. Prøv igen.";
            }
        }
        catch (Exception ex)
        {
            if (uploadVersion == _imageUploadVersion)
                UploadErrorMessage = "Fejl under upload: " + ex.Message;
        }
        finally
        {
            if (uploadVersion == _imageUploadVersion)
                IsUploadingImage = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private static async Task<string> CreatePreviewDataUrlAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(Math.Max(file.Size, MaxPreviewBytes));
        using var buffer = new MemoryStream();
        await stream.CopyToAsync(buffer);
        return $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer.ToArray())}";
    }

    // =========================
    // Save (create/update)
    // =========================

    private async Task SaveHighlightAsync()
    {
        ValidationErrorMessage = null;

        // Auth: komponenten forventer at man er logget ind.
        var user = await AuthService.GetCurrentUser();
        if (user is null)
        {
            ValidationErrorMessage = "Du skal være logget ind for at oprette highlights.";
            return;
        }

        if (IsUploadingImage)
        {
            ValidationErrorMessage = "Vent et øjeblik, billedet uploader stadig.";
            return;
        }

        // Manuelle tjek (UI har også maxlength, men vi validerer alligevel)
        if (string.IsNullOrWhiteSpace(Title) || Title.Length > 80)
        {
            ValidationErrorMessage = "Titel er påkrævet (maks 80 tegn).";
            return;
        }

        if (string.IsNullOrWhiteSpace(Description) || Description.Length > 400)
        {
            ValidationErrorMessage = "Beskrivelse er påkrævet (maks 400 tegn).";
            return;
        }

        if (HighlightToEdit is not null)
        {
            // Redigér eksisterende highlight
            HighlightToEdit.Title = Title;
            HighlightToEdit.Description = Description;
            HighlightToEdit.IsPrivate = IsPrivate;

            // Kun opdatér ImageUrl hvis vi faktisk har en URL (enten eksisterende eller ny upload)
            if (!string.IsNullOrWhiteSpace(UploadedImageUrl))
                HighlightToEdit.ImageUrl = UploadedImageUrl;

            await HighlightService.Update(HighlightToEdit);
        }
        else
        {
            // Opret nyt highlight
            var newHighlight = new Highlight
            {
                Title = Title,
                Description = Description,
                UserId = user.Id,
                ImageUrl = UploadedImageUrl, // må gerne være null
                Date = DateTime.UtcNow,      // backend sætter også Date i repo (bevarer adfærd)
                IsPrivate = IsPrivate
            };

            await HighlightService.Add(newHighlight);
        }

        // Giv parent besked om at der er sket ændringer (reload liste)
        await OnHighlightAdded.InvokeAsync();

        await Close();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Når modalen åbner, fokusér "Ja"-knappen én gang
        if (_shouldFocusConfirmButton)
        {
            _shouldFocusConfirmButton = false;
            try { await ConfirmButtonRef.FocusAsync(); } catch { }
        }
    }

    // Keyboard handling
    // =========================

    /// <summary>
    /// Enter => Confirm
    /// Escape => Cancel
    /// </summary>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter => gem/bekræft
        if (e.Key == "Enter")
            await OnEnter();

        // Escape => annuller/luk
        else if (e.Key == "Escape")
            await OnEscape();
    }

    private async Task HandleDescriptionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await OnEscape();
            return;
        }

        if (e.Key == "Enter" && e.ShiftKey)
        {
            // Shift+Enter skal lave linjeskift uden at gemme
            return;
        }

        if (e.Key == "Enter")
            await OnEnter();
    }
    
    // =========================
    // Actions
    // =========================
    private Task OnEnter() => SaveHighlightAsync();
    private Task OnEscape() => Close();

    private void StartBackdropClick()
    {
        _backdropClickStarted = true;
    }

    private async Task CloseFromBackdrop()
    {
        if (!_backdropClickStarted) return;

        _backdropClickStarted = false;
        await Close();
    }

    private async Task LockModalScrollAsync()
    {
        if (_isScrollLocked) return;
        _isScrollLocked = true;
        try { await JS.InvokeVoidAsync("whistModalLock.lock"); } catch { }
    }

    private async Task UnlockModalScrollAsync()
    {
        if (!_isScrollLocked) return;
        _isScrollLocked = false;
        try { await JS.InvokeVoidAsync("whistModalLock.unlock"); } catch { }
    }
}
