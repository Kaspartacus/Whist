@page "/kalender"
@using System.Globalization
@using Core
@using WebApp.Components
@using Microsoft.AspNetCore.Components.Web

@inject Service.CalendarServices.ICalendarService CalendarService
@inject Service.AuthServices.IAuthService AuthService

<h2>Kalender</h2>

<!-- Månedsskift -->
<div class="calendar-controls">
    <button class="btn-add" @onclick="PreviousMonth">←</button>
    <div class="calendar-current">@CurrentMonthName @CurrentYear</div>
    <button class="btn-add" @onclick="NextMonth">→</button>
</div>

<!-- År/måned dropdowns -->
<div class="calendar-filters-styled">
    <div class="filter-item dropdown">
        <label class="filter-label">Vælg år:</label>
        <div class="filter-select-wrapper">
            <span class="icon-calendar">📅</span>
            <select @bind="CurrentYear">
                @foreach (var year in YearRange)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>
    </div>

    <div class="filter-item dropdown">
        <label class="filter-label">Vælg måned:</label>
        <div class="filter-select-wrapper">
            <span class="icon-calendar">📅</span>
            <select @bind="CurrentMonth">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
            </select>
        </div>
    </div>
</div>

<!-- Kalender grid -->
<div class="calendar-grid"
     tabindex="0"
     @onkeydown="HandleKeyDown">
    @foreach (var day in DayHeaders)
    {
        <div class="day-header">@day</div>
    }

    @for (int i = 0; i < LeadingEmptyDays; i++)
    {
        <div class="day-cell empty"></div>
    }

    @for (int day = 1; day <= DaysInMonth; day++)
    {
        var date = new DateTime(CurrentYear, CurrentMonth, day);
        var isToday = date.Date == DateTime.Today;
        var cellClass = isToday ? "day-cell today" : "day-cell";

        <div class="@cellClass" @onclick="@(CurrentUser is not null ? (() => SelectDate(date)) : null)">
            <div class="day-number">@day</div>

            @if (EventDates.TryGetValue(date.Date, out var note))
            {
                <div class="event-note">@note</div>
            }
        </div>
    }
</div>

<!-- Modal: tilføj/redigér note -->
@if (ShowNoteModal && SelectedDate.HasValue && CurrentUser is not null)
{
    <div class="modal-backdrop" tabindex="0" @onkeydown="HandleKeyDown">
        <div class="modal-container">
            <h3 class="modal-title">
                @SelectedDate.Value.ToString("d. MMMM yyyy", new CultureInfo("da-DK"))
            </h3>

            <textarea class="modal-input"
                rows="4"
                maxlength="100"
                @bind="NewNote"
                @bind:event="oninput"
                @onkeydown="OnNoteKeyDown"
                @onkeydown:stopPropagation="true"
                placeholder="Skriv note eller begivenhed her..."></textarea>

            
            @* Valideringsfejl (vises kun hvis den er sat) *@
            @if (!string.IsNullOrWhiteSpace(ValidationErrorMessage))
            {
                <div style="color: red; font-size: 0.9rem;">@ValidationErrorMessage</div>
            }

            <div class="modal-actions">
                <button @ref="ConfirmButtonRef" class="modal-btn primary" @onclick="SaveNote">
                    @(EventDates.ContainsKey(SelectedDate.Value.Date) ? "Gem ændringer" : "Tilføj til kalender")
                </button>

                <button class="modal-btn cancel" @onclick="CloseModal">Annuller</button>
            </div>
        </div>
    </div>
}

<!-- Lister: tidligere/kommende begivenheder -->
@if (PastEvents.Any() || UpcomingEvents.Any())
{
    <div class="event-tables-wrapper">
        <!-- Tidligere begivenheder -->
        <div class="fine-table">
            <h3>🕘 Tidligere begivenheder</h3>

            @if (PastEvents.Any())
            {
                <table>
                    <thead>
                    <tr>
                        <th>Dato</th>
                        <th>Note</th>
                        @if (CurrentUser is not null)
                        {
                            <th></th>
                        }
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var evt in PastEvents)
                    {
                        <tr>
                            <td>@evt.Key.ToString("dd.MM.yyyy")</td>
                            <td class="event-note-cell">@evt.Value</td>
                            @if (CurrentUser is not null)
                            {
                                <td class="event-actions-cell">
                                    <button class="icon-button blue" @onclick="() => EditEvent(evt.Key)">✏️</button>
                                    <button class="icon-button red" @onclick="() => RequestDelete(evt.Key)">🗑️</button>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>

                @if (PastTotalPages > 1)
                {
                    <PaginationComponent CurrentPage="PastCurrentPage"
                                         TotalPages="PastTotalPages"
                                         OnPageChanged="LoadPastPage" />
                }
            }
            else
            {
                <p>Ingen tidligere begivenheder.</p>
            }
        </div>

        <!-- Kommende begivenheder -->
        <div class="fine-table">
            <h3>📅 Kommende begivenheder</h3>

            @if (UpcomingEvents.Any())
            {
                <table>
                    <thead>
                    <tr>
                        <th>Dato</th>
                        <th>Note</th>
                        @if (CurrentUser is not null)
                        {
                            <th></th>
                        }
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var evt in UpcomingEvents)
                    {
                        <tr>
                            <td>@evt.Key.ToString("dd.MM.yyyy")</td>
                            <td class="event-note-cell">@evt.Value</td>
                            @if (CurrentUser is not null)
                            {
                                <td class="event-actions-cell">
                                    <button class="icon-button blue" @onclick="() => EditEvent(evt.Key)">✏️</button>
                                    <button class="icon-button red" @onclick="() => RequestDelete(evt.Key)">🗑️</button>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>

                @if (UpcomingTotalPages > 1)
                {
                    <PaginationComponent CurrentPage="UpcomingCurrentPage"
                                         TotalPages="UpcomingTotalPages"
                                         OnPageChanged="LoadUpcomingPage" />
                }
            }
            else
            {
                <p>Ingen kommende begivenheder.</p>
            }
        </div>
    </div>
}

<!-- Bekræft sletning komponent -->
<ConfirmDeleteComponent @ref="confirmComponent"
                        OnConfirm="DeleteConfirmed"
                        OnCancel="CancelDelete"
                        Message="Er du sikker på at du vil slette denne begivenhed?" />

@code {
    // ------------------------------------------------------------
    // UI state
    // ------------------------------------------------------------

    private User? CurrentUser;

    private DateTime? SelectedDate;
    private string NewNote = "";
    private bool ShowNoteModal = false;

    // Bekræft-slet
    private int idToDelete;
    private DateTime dateToDelete;
    private ConfirmDeleteComponent? confirmComponent;
    
    // Fejlbesked fra validering (vises i UI)
    private string? ValidationErrorMessage;
    
    // Fokus-håndtering (så Enter virker direkte)
    private ElementReference ConfirmButtonRef;
    private bool _shouldFocusConfirmButton;

    // ------------------------------------------------------------
    // Kalender data
    // ------------------------------------------------------------

    // Dato → Note (bruges i grid + tabeller)
    private Dictionary<DateTime, string> EventDates = new();

    // Liste med alle events fra API (bruges for at finde Id ved sletning)
    private List<Core.Calendar> AllEvents = new();

    // År/måned
    private int currentYear = DateTime.Today.Year;
    private int currentMonth = DateTime.Today.Month;

    // Simpel pagination for tidligere og kommende begivenheder
    private int PastCurrentPage = 1;
    private int UpcomingCurrentPage = 1;
    private const int EventsPageSize = 5;

    // ------------------------------------------------------------
    // Computed properties (visning)
    // ------------------------------------------------------------

    private int CurrentYear
    {
        get => currentYear;
        set
        {
            if (currentYear != value)
            {
                currentYear = value;
                _ = LoadEvents(); // fire-and-forget: holder adfærd som nu
            }
        }
    }

    private int CurrentMonth
    {
        get => currentMonth;
        set
        {
            if (currentMonth != value)
            {
                currentMonth = value;
                _ = LoadEvents(); // fire-and-forget: holder adfærd som nu
            }
        }
    }

    private int DaysInMonth => DateTime.DaysInMonth(CurrentYear, CurrentMonth);

    // Mandag som første dag (da-DK)
    private int LeadingEmptyDays => ((int)new DateTime(CurrentYear, CurrentMonth, 1).DayOfWeek + 6) % 7;

    private string CurrentMonthName => CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(CurrentMonth);

    private string[] DayHeaders => new[] { "Man", "Tir", "Ons", "Tor", "Fre", "Lør", "Søn" };

    // +/- 5 år tilbage, og mange år frem
    private List<int> YearRange = Enumerable.Range(DateTime.Today.Year - 5, 56).ToList();

    private IEnumerable<KeyValuePair<DateTime, string>> AllUpcomingEvents =>
        EventDates.Where(e => e.Key >= DateTime.Today).OrderBy(e => e.Key);

    private IEnumerable<KeyValuePair<DateTime, string>> AllPastEvents =>
        EventDates.Where(e => e.Key < DateTime.Today).OrderByDescending(e => e.Key);

    private int UpcomingTotalCount => AllUpcomingEvents.Count();
    private int PastTotalCount => AllPastEvents.Count();
    private int UpcomingTotalPages => (int)Math.Ceiling((double)UpcomingTotalCount / EventsPageSize);
    private int PastTotalPages => (int)Math.Ceiling((double)PastTotalCount / EventsPageSize);

    private IEnumerable<KeyValuePair<DateTime, string>> UpcomingEvents =>
        AllUpcomingEvents
            .Skip((UpcomingCurrentPage - 1) * EventsPageSize)
            .Take(EventsPageSize);

    private IEnumerable<KeyValuePair<DateTime, string>> PastEvents =>
        AllPastEvents
            .Skip((PastCurrentPage - 1) * EventsPageSize)
            .Take(EventsPageSize);

    // ------------------------------------------------------------
    // Lifecycle
    // ------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        CurrentUser = await AuthService.GetCurrentUser();
        await LoadEvents();
    }

    // ------------------------------------------------------------
    // Data loading
    // ------------------------------------------------------------

    private async Task LoadEvents()
    {
        var allEvents = await CalendarService.GetAll();
        AllEvents = allEvents;

        // OBS: Vi viser dato i lokal tid i UI.
        EventDates = allEvents
            .GroupBy(e => e.Date.ToLocalTime().Date)
            .ToDictionary(g => g.Key, g => g.First().Note);

        // Holder pagination på gyldige sider efter ændringer
        PastCurrentPage = NormalizePage(PastCurrentPage, PastTotalPages);
        UpcomingCurrentPage = NormalizePage(UpcomingCurrentPage, UpcomingTotalPages);
        
        _shouldFocusConfirmButton = true;
        
        StateHasChanged();
    }

    // ------------------------------------------------------------
    // UI actions
    // ------------------------------------------------------------

    private void SelectDate(DateTime date)
    {
        if (CurrentUser is null)
            return;
        
        ValidationErrorMessage = null;

        SelectedDate = date;
        NewNote = EventDates.TryGetValue(date.Date, out var note) ? note : "";
        ShowNoteModal = true;
        _shouldFocusConfirmButton = true;

    }

    private void CloseModal()
    {
        SelectedDate = null;
        NewNote = "";
        ShowNoteModal = false;
        ValidationErrorMessage = null;
    }

    private async Task SaveNote()
    {
        if (!SelectedDate.HasValue)
            return;
        
        ValidationErrorMessage = null;

        var calendar = new Core.Calendar
        {
            Date = SelectedDate.Value.Date,
            Note = NewNote
        };
        
        // --- Validering (hurtig og tydelig) ---
        if (string.IsNullOrWhiteSpace(calendar.Note))
        {
            ValidationErrorMessage = "Note er påkrævet.";
            return;
        }

        if (calendar.Note.Length > 100)
        {
            ValidationErrorMessage = "Regeltekst må maks være 100 tegn.";
            return;
        }
        
        

        // --- Gem ---
        if (calendar is not null)
        {
            await CalendarService.Save(calendar);
        }
        
        await LoadEvents();

        CloseModal();
    }

    private async Task PreviousMonth()
    {
        if (CurrentMonth == 1)
        {
            CurrentMonth = 12;
            CurrentYear--;
        }
        else
        {
            CurrentMonth--;
        }

        await LoadEvents();
    }

    private async Task NextMonth()
    {
        if (CurrentMonth == 12)
        {
            CurrentMonth = 1;
            CurrentYear++;
        }
        else
        {
            CurrentMonth++;
        }

        await LoadEvents();
    }

    private void EditEvent(DateTime date) => SelectDate(date);

    // ------------------------------------------------------------
    // Sletning (via ConfirmDeleteComponent)
    // ------------------------------------------------------------

    private void RequestDelete(DateTime date)
    {
        // Find matchende event, så vi kan slette via Id
        var calendar = AllEvents.FirstOrDefault(e => e.Date.Date == date.Date);
        if (calendar is null)
            return;

        idToDelete = calendar.Id;
        dateToDelete = calendar.Date;

        confirmComponent?.Show();
    }

    private async Task DeleteConfirmed()
    {
        await CalendarService.Delete(idToDelete);

        // Fjern fra lokalt cache (og refresh bagefter)
        EventDates.Remove(dateToDelete);

        if (SelectedDate == dateToDelete)
        {
            CloseModal();
        }

        await LoadEvents();
    }

    private void CancelDelete()
    {
        dateToDelete = default;
    }

    private Task LoadPastPage(int page)
    {
        PastCurrentPage = NormalizePage(page, PastTotalPages);
        return Task.CompletedTask;
    }

    private Task LoadUpcomingPage(int page)
    {
        UpcomingCurrentPage = NormalizePage(page, UpcomingTotalPages);
        return Task.CompletedTask;
    }

    private static int NormalizePage(int page, int totalPages)
    {
        if (totalPages <= 0)
            return 1;

        if (page < 1)
            return 1;

        return page > totalPages ? totalPages : page;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Når modalen åbner, fokusér "Ja"-knappen én gang
        if (_shouldFocusConfirmButton)
        {
            _shouldFocusConfirmButton = false;
            try { await ConfirmButtonRef.FocusAsync(); } catch { }
        }
    }

    // Keyboard handling
    // =========================

    /// <summary>
    /// Enter => Confirm
    /// Escape => Cancel
    /// </summary>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter => gem/bekræft
        if (e.Key == "Enter")
            await OnEnter();

        // Escape => annuller/luk
        else if (e.Key == "Escape")
            await OnEscape();
    }
    
    /// <summary>
    /// Enter of escape i note
    /// </summary>
    private async Task OnNoteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await OnEscape(); // din cancel/luk
            return;
        }
        
        if (e.Key == "Enter" && e.ShiftKey)
        {
            // Shift+Enter skal lave linjeskift uden at gemme
            return;
        }

        if (e.Key == "Enter")
        {
            // Ellers: Enter = gem/confirm
            await OnEnter();
        }
    }
    
    // =========================
    // Actions
    // =========================
    private Task OnEnter() => SaveNote();
    private Task OnEscape() { CloseModal(); return Task.CompletedTask; }
}
