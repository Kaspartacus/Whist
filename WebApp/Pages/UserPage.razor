@page "/medlemmer"

@using Core
@using WebApp.Components
@using WebApp.Service
@using WebApp.Service.AuthServices

@inject IUserService UserService
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="top-bar">
    <h2>Medlemmer</h2>

    @* Alle loggede brugere må oprette nye medlemmer. *@
    <AuthorizeView>
        <Authorized>
            <button class="btn-add" @onclick="OpenAddUserModal">+ Tilføj medlem</button>
        </Authorized>
    </AuthorizeView>
</div>

@* Modal/component til opret/redigér *@
<AddUserComponent @ref="addUserComponent"
                  OnUserAdded="ReloadUsers"
                  CurrentUserId="CurrentUser?.Id"
                  IsAdmin="IsAdmin" />

<div class="page-container">
    @foreach (var user in Users)
    {
        <div class="user-card">
            <!-- Venstre kolonne: billede + kontaktinfo -->
            <div class="user-left">
                @if (!string.IsNullOrEmpty(user.ImageUrl))
                {
                    <img class="user-image" src="@user.ImageUrl" alt="Billede af @user.NickName" />
                }

                <div class="user-name"><strong>@user.Name</strong></div>
                <div class="user-nickname">"@user.NickName"</div>

                <AuthorizeView>
                    <Authorized>
                    <div class="user-contact">
                        <div class="contact-row">
                            <i class="bi bi-envelope"></i>
                            <span class="contact-text">@user.Email</span>
                        </div>

                        <div class="contact-row">
                            <i class="bi bi-telephone"></i>
                            <span class="contact-text">@user.PhoneNumber</span>
                        </div>

                        <div class="contact-row">
                            <i class="bi bi-geo-alt"></i>
                            <span class="contact-text">@user.Address</span>
                        </div>
                    </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <!-- Højre kolonne: fun fact + beskrivelse + actions -->
            <div class="user-right">
                @if (!string.IsNullOrEmpty(user.FunFact))
                {
                    <div class="fun-fact">
                        <i class="fa fa-comment-dots"></i>
                        <div>
                            <strong>Fun Fact:</strong><br />
                            @user.FunFact
                        </div>
                    </div>
                }

                <div class="about-section">
                    <h4>Om @user.NickName</h4>
                    <p>@user.Description</p>
                </div>

                @if (CanEditUser(user) || CanDeleteUser(user))
                {
                    <div class="actions">
                        @if (CanEditUser(user))
                        {
                            <button class="icon-button blue" title="Redigér" @onclick="() => EditUser(user)">✏️</button>
                        }

                        @if (CanDeleteUser(user))
                        {
                            <button class="icon-button red" title="Slet" @onclick="() => ConfirmDeleteUser(user)">🗑️</button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Bekræft sletning *@
<ConfirmDeleteComponent @ref="confirmDeleteComponent"
                        OnConfirm="DeleteConfirmed"
                        OnCancel="CancelDelete"
                        Message="Er du sikker på at du vil slette denne bruger?" />

@code {
    // =========================
    // State
    // =========================
    private List<User> Users = new();
    private User? CurrentUser;
    private bool IsAdmin;

    private AddUserComponent? addUserComponent;

    // Slet-flow
    private User? UserToDelete;
    private ConfirmDeleteComponent? confirmDeleteComponent;

    // =========================
    // Lifecycle
    // =========================
    protected override async Task OnInitializedAsync()
    {
        CurrentUser = await AuthService.GetCurrentUser();
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsAdmin = authState.User.IsInRole("Admin");

        await LoadUsers();
    }

    // =========================
    // Data
    // =========================
    private async Task LoadUsers()
    {
        Users = (await UserService.GetAll()).ToList();
    }

    private async Task ReloadUsers()
    {
        await LoadUsers();
        await InvokeAsync(StateHasChanged);
    }

    private bool IsOwnUser(User user)
        => CurrentUser?.Id == user.Id;

    private bool CanEditUser(User user)
        => IsAdmin || IsOwnUser(user);

    private bool CanDeleteUser(User user)
        => IsOwnUser(user) ? !IsAdmin : IsAdmin;

    // =========================
    // UI actions
    // =========================
    private void OpenAddUserModal()
        => addUserComponent?.Show();

    private async Task EditUser(User user)
    {
        if (addUserComponent is not null)
            await addUserComponent.Show(user);
    }

    // =========================
    // Delete flow
    // =========================
    private void ConfirmDeleteUser(User user)
    {
        UserToDelete = user;
        confirmDeleteComponent?.Show();
    }

    private async Task DeleteConfirmed()
    {
        if (UserToDelete is null) return;

        await UserService.Delete(UserToDelete.Id);
        UserToDelete = null;

        await ReloadUsers();
    }

    private void CancelDelete()
        => UserToDelete = null;
}
