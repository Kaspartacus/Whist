{
  "BlobStorage": {
    "ContainerName": "images",
    "MaxUploadBytes": 5242880,
    "MaxImageWidth": 1600,
    "WebpQuality": 82
  },
  "Database": {
    "SharedThroughput": 1000,
    "Containers": {
      "Users": "users",
      "Roles": "identityRoles",
      "RefreshTokens": "refreshTokens",
      "Highlights": "highlights",
      "Counters": "counters",
      "Points": "points",
      "Calendar": "calendar",
      "Rules": "rules"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5102",
      "https://localhost:7080"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
